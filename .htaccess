# NEXTHELP HOSTINGER ROUTING CONFIGURATION
# ----------------------------------------
# Este arquivo configura o roteamento no servidor Apache/LiteSpeed da Hostinger.
# Ele garante que as requisições para a API (/api/*) e configurações (/config.js)
# sejam repassadas para o processo Node.js (Express), enquanto os arquivos estáticos
# são servidos diretamente para máxima performance.

# 1. Configuração do Phusion Passenger (Padrão da Hostinger para Node.js)
<IfModule mod_passenger.c>
    PassengerEnabled on
    PassengerAppType node
    PassengerStartupFile server.cjs
</IfModule>

# 2. Configurações de Reescrita (mod_rewrite)
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Permitir acesso direto a arquivos reais existentes no servidor (imagens, css, js, etc.)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Se a requisição for para /api/* ou /config.js, envie diretamente para o Node.js (server.cjs)
    RewriteRule ^api/(.*)$ server.cjs [QSA,L]
    RewriteRule ^config\.js$ server.cjs [QSA,L]

    # Tenta servir arquivos estáticos diretamente da pasta dist/ se eles existirem lá
    RewriteCond %{DOCUMENT_ROOT}/dist/$1 -f
    RewriteRule ^(.*)$ dist/$1 [L]

    # Qualquer outra rota da SPA (Single Page Application) que não seja um arquivo físico,
    # deve ser tratada pelo Express (server.cjs) para gerenciar o roteamento e fallback do index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ server.cjs [QSA,L]
</IfModule>

# 3. Caso o Hostinger use Proxy Reverso em Porta Customizada (opcional)
# Se você configurou o Node.js para rodar em uma porta específica (ex: 3000) e não via Passenger,
# descomente as linhas abaixo para encaminhar todo o tráfego da API para a porta correspondente:
# <IfModule mod_proxy.c>
#     ProxyPass /api/ http://127.0.0.1:3000/api/
#     ProxyPassReverse /api/ http://127.0.0.1:3000/api/
#     ProxyPass /config.js http://127.0.0.1:3000/config.js
#     ProxyPassReverse /config.js http://127.0.0.1:3000/config.js
# </IfModule>
